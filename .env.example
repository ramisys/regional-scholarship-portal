# Django
DJANGO_SECRET_KEY=your-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=example.com,www.example.com

# Postgres
POSTGRES_DB=scholarship_portal
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Cloudinary (required in production)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@example.com

# Frontend
FRONTEND_RESET_PASSWORD_URL=https://example.com/reset-password

# Throttling (optional)
THROTTLE_ANON=60/minute
THROTTLE_USER=240/minute
THROTTLE_AUTH=20/minute
THROTTLE_UPLOAD=30/minute
